{
  "name": "@galley/desktop",
  "version": "0.6.3",
  "private": true,
  "type": "module",
  "description": "Galley desktop app (Tauri 2 + Svelte 5).",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
